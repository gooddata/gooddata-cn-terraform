# Copy to providers.env (gitignored) and fill in secrets.

# --- GoodData CN org ---
TIGER_ENDPOINT="https://gooddata.local-inference.dev11.devgdc.com"
TIGER_API_TOKEN=""           # org API token (create after deploy)

# --- vLLM (in-cluster alternative server, same GPU pool) ---
REGISTER_VLLM=false
VLLM_BASE_URL="http://vllm.inference.svc.cluster.local:8000/v1"
VLLM_API_KEY="local"         # unauthenticated in-cluster server; any non-empty string
VLLM_MODEL="Qwen/Qwen3.6-27B"

# --- SIE SELF-HOSTED in our cluster (deploy/helm/install-sie.sh) — PRIMARY ---
REGISTER_SIE=true
SIE_BASE_URL="http://sie-gateway.sie.svc.cluster.local:8080/v1"
SIE_API_KEY="local"          # gateway auth mode=none (in-cluster only)
SIE_MODEL="Qwen/Qwen3-0.6B"  # small model fits L4; 27B needs a100-80gb / FP8 profile
# Managed-cluster alternative (Superlinked-hosted, us-east-2):
#SIE_BASE_URL="http://a64e1dc31032c40e4b1e9330a1273c83-1760332796.us-east-2.elb.amazonaws.com:8080/v1"
#SIE_API_KEY=""              # SL-... token
#SIE_MODEL="Qwen/Qwen3.6-27B"
