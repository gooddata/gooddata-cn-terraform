monitoring:
  tracing:
    enabled: true
    pythonOtelExporterType: "otlp-grpc"
    zipkin:
      host: "tempo"
      namespace: "${observability_namespace}"
      port: 9411
    otel:
      grpc:
        host: "tempo"
        namespace: "${observability_namespace}"
        port: 4317

# Enable Pod Monitors on all GoodData.CN services
podMonitor:
  enabled: true
