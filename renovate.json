{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>gooddata/.github:renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_cert_manager_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "cert-manager",
      "registryUrlTemplate": "https://charts.jetstack.io"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_metrics_server_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "metrics-server",
      "registryUrlTemplate": "https://kubernetes-sigs.github.io/metrics-server/"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_pulsar_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "pulsar",
      "registryUrlTemplate": "https://pulsar.apache.org/charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_ingress_nginx_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "ingress-nginx",
      "registryUrlTemplate": "https://kubernetes.github.io/ingress-nginx"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/settings\\.tfvars\\.example$"],
      "matchStrings": [
        "helm_gdcn_version\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "gooddata-cn",
      "registryUrlTemplate": "https://charts.gooddata.com/"
    },
    {
      "customType": "regex",
      "fileMatch": ["^aws/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"eks_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "endoflife-date",
      "depNameTemplate": "amazon-eks"
    },
    {
      "customType": "regex",
      "fileMatch": ["^aws/settings\\.tfvars\\.example$"],
      "matchStrings": [
        "#\\s*eks_version\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "endoflife-date",
      "depNameTemplate": "amazon-eks"
    },
    {
      "customType": "regex",
      "fileMatch": ["^azure/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"aks_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "endoflife-date",
      "depNameTemplate": "azure-kubernetes-service"
    },
    {
      "customType": "regex",
      "fileMatch": ["^azure/settings\\.tfvars\\.example$"],
      "matchStrings": [
        "#\\s*aks_version\\s*=\\s*\"(?<currentValue>\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "endoflife-date",
      "depNameTemplate": "azure-kubernetes-service"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_aws_lb_controller_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "aws-load-balancer-controller",
      "registryUrlTemplate": "https://aws.github.io/eks-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_cluster_autoscaler_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "cluster-autoscaler",
      "registryUrlTemplate": "https://kubernetes.github.io/autoscaler"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_external_dns_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "external-dns",
      "registryUrlTemplate": "https://kubernetes-sigs.github.io/external-dns/"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$", "^modules/[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_cnpg_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "cloudnative-pg",
      "registryUrlTemplate": "https://cloudnative-pg.github.io/charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_grafana_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "grafana",
      "registryUrlTemplate": "https://grafana.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_istio_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "base",
      "registryUrlTemplate": "https://istio-release.storage.googleapis.com/charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_loki_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "loki",
      "registryUrlTemplate": "https://grafana.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_prometheus_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "kube-prometheus-stack",
      "registryUrlTemplate": "https://prometheus-community.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_promtail_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "promtail",
      "registryUrlTemplate": "https://grafana.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_tempo_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "tempo",
      "registryUrlTemplate": "https://grafana.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^modules/[^/]+/variables\\.tf$"],
      "matchStrings": [
        "variable\\s+\"helm_seaweedfs_version\"[\\s\\S]*?default\\s*=\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+)\""
      ],
      "datasourceTemplate": "helm",
      "depNameTemplate": "seaweedfs",
      "registryUrlTemplate": "https://seaweedfs.github.io/seaweedfs/helm"
    }
  ]
}
